  updatedAt      DateTime     @updatedAt @map("updated_at")

  assessment Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  bankItem   QuestionBankItem? @relation(fields: [bankItemId], references: [id], onDelete: SetNull)

  @@index([assessmentId])
  @@index([bankItemId])
  @@index([sortOrder])
  @@index([deletedAt])
  @@map("assessment_questions")
}

model AssessmentAttempt {
  id             String        @id @default(cuid())
  assessmentId   String        @map("assessment_id")
  userId         String        @map("user_id")
  attemptNumber  Int           @default(1) @map("attempt_number")
  status         AttemptStatus @default(IN_PROGRESS)
  score          Int?
  maxScore       Int?          @map("max_score")
  passingScore   Int?          @map("passing_score")
  passed         Boolean?
  answers        Json?
  feedback       String?
  startedAt      DateTime      @default(now()) @map("started_at")
  expiresAt      DateTime?     @map("expires_at")
  submittedAt    DateTime?     @map("submitted_at")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([userId])
  @@index([status])
  @@index([passed])
  @@index([deletedAt])
  @@map("assessment_attempts")
}

// ─── Certifications ────────────────────────────────────────────

model CertificateTemplate {
  id            String    @id @default(cuid())
  name          String
  description   String?
  templateHtml  String?   @map("template_html")
  issuerName    String?   @map("issuer_name")
  validityDays  Int?      @map("validity_days")
  isActive      Boolean   @default(true) @map("is_active")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  certificates  Certificate[]
  skillMappings SkillCertificateMapping[]
  levelPaths    SkillLevelPath[]
  certificateProgressRecords CertificateProgressRecord[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("certificate_templates")
}

model Certificate {
  id                String            @id @default(cuid())
  userId            String            @map("user_id")
  templateId        String            @map("template_id")
  courseId          String?           @map("course_id")
  assessmentId      String?           @map("assessment_id")
  certificateNumber String            @unique @map("certificate_number")
  verificationToken String            @unique @map("verification_token")
  status            CertificateStatus @default(ACTIVE)
  issuedById        String?           @map("issued_by_id")
  renewedFromId     String?           @map("renewed_from_id")
  renewedAt         DateTime?         @map("renewed_at")
  revokedAt         DateTime?         @map("revoked_at")
  revokedReason     String?           @map("revoked_reason")
  issuedAt          DateTime          @default(now()) @map("issued_at")
  expiresAt         DateTime?         @map("expires_at")
  deletedAt         DateTime?         @map("deleted_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  template    CertificateTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  course      Course?             @relation(fields: [courseId], references: [id], onDelete: SetNull)
  assessment  Assessment?         @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  issuedBy    User?               @relation("CertificateIssuer", fields: [issuedById], references: [id], onDelete: SetNull)
  renewedFrom Certificate?        @relation("CertificateRenewal", fields: [renewedFromId], references: [id], onDelete: SetNull)
  renewals    Certificate[]       @relation("CertificateRenewal")

  @@index([userId])
  @@index([templateId])
  @@index([courseId])
  @@index([assessmentId])
  @@index([certificateNumber])
  @@index([verificationToken])
  @@index([status])
  @@index([expiresAt])
  @@index([deletedAt])
  @@map("certificates")
}

// ─── Notifications ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType @default(INFO)
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  actionUrl String?          @map("action_url")
  deletedAt DateTime?        @map("deleted_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("notifications")
}

// ─── Audit & System ────────────────────────────────────────────

model AccessRequest {
  id              String              @id @default(cuid())
  userId          String              @map("user_id")
  requesterRole   String?             @map("requester_role")
  moduleName      String              @map("module_name")
  resourcePath    String              @map("resource_path")
  requiredPermission String           @map("required_permission")
  reason          String?
  status          AccessRequestStatus @default(PENDING)
  requestedAt     DateTime            @default(now()) @map("requested_at")
  reviewedById    String?             @map("reviewed_by_id")
  reviewedAt      DateTime?           @map("reviewed_at")
  reviewNotes     String?             @map("review_notes")
  deletedAt       DateTime?           @map("deleted_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  user       User  @relation("AccessRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("AccessReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resourcePath])
  @@index([requiredPermission])
  @@index([status])
  @@index([createdAt])
  @@index([requestedAt])
  @@index([deletedAt])
  @@map("access_requests")
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String?     @map("entity_id")
  actorId    String?     @map("actor_id")
  metadata   Json?
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id          String           @id @default(cuid())
  key         String           @unique
  value       String
  valueType   SettingValueType @default(STRING) @map("value_type")
  description String?
  isPublic    Boolean          @default(false) @map("is_public")
  deletedAt   DateTime?        @map("deleted_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([key])
  @@index([isPublic])
  @@index([deletedAt])
  @@map("system_settings")
}

// ─── Performance & Succession ──────────────────────────────────

model PerformanceReview {
  id                    String                @id @default(cuid())
  userId                String                @map("user_id")
  reviewerId            String                @map("reviewer_id")
  periodStart           DateTime              @map("period_start")
  periodEnd             DateTime              @map("period_end")
  rating                PerformanceRating
  score                 Float
  managerRecommendation ManagerRecommendation @map("manager_recommendation")
  promotionTarget       String?               @map("promotion_target")
  notes                 String?
  deletedAt             DateTime?             @map("deleted_at")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  user     User @relation("ReviewSubject", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reviewerId])
  @@index([periodEnd])
  @@index([deletedAt])
  @@map("performance_reviews")
}

model CriticalRole {
  id                 String    @id @default(cuid())
  title              String
  jobRoleId          String?   @map("job_role_id")
  departmentId       String?   @map("department_id")
  holderId           String?   @map("holder_id")
  isCritical         Boolean   @default(true) @map("is_critical")
  retirementRiskScore Int      @default(0) @map("retirement_risk_score")
  attritionRiskScore Int       @default(0) @map("attrition_risk_score")
  benchStrength      Int       @default(0) @map("bench_strength")
  coverageScore      Int       @default(0) @map("coverage_score")
  riskScore          Int       @default(0) @map("risk_score")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  jobRole     JobRole?              @relation(fields: [jobRoleId], references: [id], onDelete: SetNull)
  department  Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  holder      User?                 @relation("CriticalRoleHolder", fields: [holderId], references: [id], onDelete: SetNull)
  successors  SuccessionSuccessor[]

  @@index([jobRoleId])
  @@index([departmentId])
  @@index([holderId])
  @@index([deletedAt])
  @@map("critical_roles")
}

model SuccessionSuccessor {
  id              String              @id @default(cuid())
  criticalRoleId  String              @map("critical_role_id")
  candidateId     String              @map("candidate_id")
  readiness       SuccessionReadiness
  readinessScore  Int                 @map("readiness_score")
  skillGapSummary String?             @map("skill_gap_summary")
  notes           String?
  deletedAt       DateTime?           @map("deleted_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  criticalRole CriticalRole @relation(fields: [criticalRoleId], references: [id], onDelete: Cascade)
  candidate    User         @relation("SuccessionCandidate", fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([criticalRoleId, candidateId])
  @@index([criticalRoleId])
  @@index([candidateId])
  @@index([readiness])
  @@index([deletedAt])
  @@map("succession_successors")
}

// ─── Talent Marketplace ────────────────────────────────────────

model TalentOpportunity {
  id              String                @id @default(cuid())
  title           String
  type            TalentOpportunityType
  departmentId    String?               @map("department_id")
  jobRoleId       String?               @map("job_role_id")
  description     String?
  requiredSkills  Json?                 @map("required_skills")
  learningNeeded  String?               @map("learning_needed")
  isOpen          Boolean               @default(true) @map("is_open")
  postedById      String                @map("posted_by_id")
  closesAt        DateTime?             @map("closes_at")
  deletedAt       DateTime?             @map("deleted_at")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  department   Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobRole      JobRole?              @relation(fields: [jobRoleId], references: [id], onDelete: SetNull)
  postedBy     User                  @relation("OpportunityPoster", fields: [postedById], references: [id], onDelete: Cascade)
  applications MobilityApplication[]

  @@index([departmentId])
  @@index([jobRoleId])
  @@index([isOpen])
  @@index([postedById])
  @@index([deletedAt])
  @@map("talent_opportunities")
}

model MobilityApplication {
  id              String                    @id @default(cuid())
  opportunityId   String                    @map("opportunity_id")
  applicantId     String                    @map("applicant_id")
  matchScore      Int                       @map("match_score")
  readinessScore  Int                       @map("readiness_score")
  status          MobilityApplicationStatus @default(PENDING)
  notes           String?
  reviewedAt      DateTime?                 @map("reviewed_at")
  deletedAt       DateTime?                 @map("deleted_at")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  opportunity TalentOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  applicant   User              @relation("MobilityApplicant", fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, applicantId])
  @@index([opportunityId])
  @@index([applicantId])
  @@index([status])
  @@index([deletedAt])
  @@map("mobility_applications")
}

// ─── Workforce Forecasting ─────────────────────────────────────

model WorkforceForecast {
  id              String             @id @default(cuid())
  category        ForecastCategory
  modelType       ForecastModelType  @map("model_type")
  departmentId    String?            @map("department_id")
  skillId         String?            @map("skill_id")
  horizonMonths   Int                @map("horizon_months")
  predictedValue  Float              @map("predicted_value")
  confidence      Float
  drivers         Json
  recommendations Json
  generatedAt     DateTime           @default(now()) @map("generated_at")
  deletedAt       DateTime?          @map("deleted_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  skill      Skill?      @relation(fields: [skillId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([modelType])
  @@index([departmentId])
  @@index([skillId])
  @@index([generatedAt])
  @@index([deletedAt])
  @@map("workforce_forecasts")
}

// ─── Screen Registry & Access ──────────────────────────────────

model Screen {
  id                 String   @id @default(cuid())
  key                String   @unique
  label              String
  description        String?
  route              String   @unique
  section            String
  icon               String
  parentKey          String?  @map("parent_key")
  sectionOrder       Int      @map("section_order")
  order              Int
  requiredPermission String?  @map("required_permission")
  isSidebarItem      Boolean  @default(true) @map("is_sidebar_item")
  isActive           Boolean  @default(true) @map("is_active")
  isSystem           Boolean  @default(false) @map("is_system")
  isPersonal         Boolean  @default(false) @map("is_personal")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  roleScreenAccess   RoleScreenAccess[]
  userScreenOverrides UserScreenOverride[]
  screenAccessAudits ScreenAccessAudit[]

  @@index([section, order])
  @@index([sectionOrder, order])
  @@index([isActive, isSidebarItem])
  @@map("screens")
}

model RoleScreenAccess {
  id        String   @id @default(cuid())
  roleId    String   @map("role_id")
  screenId  String   @map("screen_id")
  enabled   Boolean  @default(false)
  canView   Boolean  @default(false) @map("can_view")
  canCreate Boolean  @default(false) @map("can_create")
  canUpdate Boolean  @default(false) @map("can_update")
  canDelete Boolean  @default(false) @map("can_delete")
  canManage Boolean  @default(false) @map("can_manage")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  screen Screen @relation(fields: [screenId], references: [id], onDelete: Cascade)

  @@unique([roleId, screenId])
  @@index([roleId, enabled])
  @@index([screenId])
  @@map("role_screen_access")
}

model UserScreenOverride {
  id           String              @id @default(cuid())
  userId       String              @map("user_id")
  screenId     String              @map("screen_id")
  enabled      Boolean?
  overrideType ScreenOverrideType  @map("override_type")
  reason       String?
  expiresAt    DateTime?           @map("expires_at")
  createdById  String?             @map("created_by_id")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  screen    Screen @relation(fields: [screenId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("ScreenOverrideCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([userId, screenId])
  @@index([userId])
  @@index([screenId])
  @@index([expiresAt])
  @@map("user_screen_overrides")
}

model ScreenAccessAudit {
  id           String   @id @default(cuid())
  actorId      String   @map("actor_id")
  targetRoleId String?  @map("target_role_id")
  targetUserId String?  @map("target_user_id")
  screenId     String   @map("screen_id")
  action       String
  beforeJson   String?  @map("before_json")
  afterJson    String?  @map("after_json")
  createdAt    DateTime @default(now()) @map("created_at")

  actor  User   @relation("ScreenAccessAuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  screen Screen @relation(fields: [screenId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([targetRoleId])
  @@index([targetUserId])
  @@index([screenId])
  @@index([createdAt])
  @@map("screen_access_audits")
}
