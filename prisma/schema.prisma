// TalentIQ — Complete PostgreSQL Schema
// Source of truth: docs/PROJECT_CONTEXT.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  REFRESH_TOKEN
  PASSWORD_CHANGE
  PERMISSION_DENIED
  EXPORT
  IMPORT
  COPILOT_QUERY
  ACCESS_REQUEST
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  DROPPED
}

enum LessonType {
  VIDEO
  PDF
  QUIZ
  ASSIGNMENT
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum LearningResourceType {
  LINK
  YOUTUBE
  PDF
  DOCUMENT
  VIDEO
  MICROSOFT_LEARN
  UDEMY
  COURSERA
  OTHER
}

enum OpenCourseCategory {
  PRODUCT
  HR_POLICIES
  SECURITY
  GENERAL
}

enum CourseAdminStatus {
  ACTIVE
  INACTIVE
}

enum CourseLevelTier {
  BASIC
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum AssignmentTargetType {
  USER
  DEPARTMENT
  TEAM
  ROLE
  ORGANIZATION
}

enum CourseAssignmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum CertificateStatus {
  ACTIVE
  EXPIRED
  REVOKED
  RENEWED
}

enum RoadmapStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum AssessmentType {
  QUIZ
  PRACTICAL
  CERTIFICATION
  SKILL_CHECK
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  CODE
  ESSAY
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  PASSED
  FAILED
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ACTION_REQUIRED
  SYSTEM
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

enum SsoProvider {
  OKTA
  AZURE_AD
  GOOGLE
}

enum UserPermissionEffect {
  GRANT
  DENY
}

enum SkillRelationType {
  PREREQUISITE
  RELATED
  COMPLEMENTARY
}

enum XapiVerb {
  STARTED
  PAUSED
  RESUMED
  COMPLETED
  PASSED
  FAILED
  VIEWED
  DOWNLOADED
  CERTIFIED
}

enum LearningEventSource {
  INTERNAL
  SCORM
  XAPI
  EXTERNAL
}

enum ExternalLearningProvider {
  LINKEDIN_LEARNING
  COURSERA
  UDEMY_BUSINESS
  PLURALSIGHT
  SKILLSOFT
}

enum PerformanceRating {
  EXCEPTIONAL
  EXCEEDS
  MEETS
  DEVELOPING
  UNSATISFACTORY
}

enum ManagerRecommendation {
  STRONG
  RECOMMENDED
  NEUTRAL
  NOT_READY
}

enum SuccessionReadiness {
  READY_NOW
  READY_6_MONTHS
  READY_12_MONTHS
  DEVELOPING
}

enum TalentOpportunityType {
  PROMOTION
  LATERAL
  CROSS_FUNCTIONAL
  PROJECT
}

enum MobilityApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum ForecastModelType {
  XGBOOST
  LIGHTGBM
  RANDOM_FOREST
}

enum ForecastCategory {
  ATTRITION
  HIRING
  LEADERSHIP_GAP
  CERTIFICATION_EXPIRATION
  SKILL_DEMAND
  WORKFORCE_GROWTH
}

enum CertificateProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  EARNED
  EXPIRED
}

enum ScreenOverrideType {
  ALLOW
  DENY
}

// ─── RBAC ──────────────────────────────────────────────────────

model Role {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  isSystem    Boolean   @default(false) @map("is_system")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  users              User[]
  rolePermissions    RolePermission[]
  roleScreenAccess   RoleScreenAccess[]

  @@index([slug])
  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id          String    @id @default(cuid())
  key         String    @unique
  name        String
  description String?
  module      String
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@index([module])
  @@index([key])
  @@index([deletedAt])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           String               @id @default(cuid())
  userId       String               @map("user_id")
  permissionId String               @map("permission_id")
  effect       UserPermissionEffect @default(GRANT)
  deletedAt    DateTime?            @map("deleted_at")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
  @@index([deletedAt])
  @@map("user_permissions")
}

// ─── Organization ──────────────────────────────────────────────

model Department {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  description String?
  parentId    String?   @map("parent_id")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Department[] @relation("DepartmentHierarchy")
  teams              Team[]
  users              User[]
  jobRoles           JobRole[]
  criticalRoles      CriticalRole[]
  talentOpportunities TalentOpportunity[]
  workforceForecasts WorkforceForecast[]

  @@index([code])
  @@index([parentId])
  @@index([deletedAt])
  @@map("departments")
}

model Team {
  id           String    @id @default(cuid())
  name         String
  code         String    @unique
  description  String?
  departmentId String    @map("department_id")
  leaderId     String?   @map("leader_id")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  leader     User?      @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  members    User[]     @relation("TeamMembers")

  @@index([departmentId])
  @@index([leaderId])
  @@index([code])
  @@index([deletedAt])
  @@map("teams")
}

// ─── User & Auth ───────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String?   @map("password_hash")
  firstName         String    @map("first_name")
  lastName          String    @map("last_name")
  roleId            String    @map("role_id")
  departmentId      String?   @map("department_id")
  teamId            String?   @map("team_id")
  jobRoleId         String?   @map("job_role_id")
  experienceLevelId String?   @map("experience_level_id")
  managerId         String?   @map("manager_id")
  isActive          Boolean   @default(true) @map("is_active")
  emailVerifiedAt   DateTime? @map("email_verified_at")
  emailVerificationTokenHash String? @map("email_verification_token_hash")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  passwordResetTokenHash String? @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  passwordChangedAt DateTime? @map("password_changed_at")
  lastLoginAt       DateTime? @map("last_login_at")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  role              Role              @relation(fields: [roleId], references: [id], onDelete: Restrict)
  department        Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  team              Team?             @relation("TeamMembers", fields: [teamId], references: [id], onDelete: SetNull)
  jobRole           JobRole?          @relation(fields: [jobRoleId], references: [id], onDelete: SetNull)
  experienceLevel   ExperienceLevel?  @relation(fields: [experienceLevelId], references: [id], onDelete: SetNull)
  manager           User?             @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports     User[]            @relation("UserManager")
  ledTeams          Team[]            @relation("TeamLeader")
  userPermissions   UserPermission[]
  sessions          RefreshToken[]
  auditLogs         AuditLog[]        @relation("AuditActor")
  employeeSkills    EmployeeSkill[]   @relation("EmployeeSkills")
  verifiedSkills    EmployeeSkill[]   @relation("SkillVerifier")
  instructedCourses Course[]          @relation("CourseInstructor")
  enrollments       CourseEnrollment[]
  learningRoadmaps  LearningRoadmap[]
  assessmentAttempts AssessmentAttempt[]
  certificates      Certificate[]
  notifications     Notification[]
  lessonProgress       LessonProgress[]
  issuedCertificates   Certificate[]     @relation("CertificateIssuer")
  learningResources    LearningResource[] @relation("LearningResourceCreator")
  learningResourceAssignmentsCreated LearningResourceAssignment[] @relation("LearningResourceAssigner")
  learningResourceAssignmentsReceived LearningResourceAssignment[] @relation("LearningResourceAssignee")
  openCoursesCreated   OpenCourse[]       @relation("OpenCourseCreator")
  openCourseCompletions OpenCourseCompletion[]
  openCourseAssignmentsCreated OpenCourseAssignment[] @relation("OpenCourseAssigner")
  openCourseAssignmentsReceived OpenCourseAssignment[] @relation("OpenCourseAssignee")
  coursesCreated               Course[]               @relation("CourseCreator")
  assignmentBatchesCreated     CourseAssignmentBatch[] @relation("AssignmentBatchCreator")
  courseAssignmentsGiven       CourseAssignmentUser[] @relation("CourseAssignmentAssigner")
  courseAssignmentsReceived    CourseAssignmentUser[] @relation("CourseAssignmentAssignee")
  learningEvents              LearningEvent[]
  courseProgressRecords         CourseProgressRecord[]
  assessmentProgressRecords     AssessmentProgressRecord[]
  certificateProgressRecords    CertificateProgressRecord[]
  externalLearningRecords       ExternalLearningRecord[]
  accessRequests                AccessRequest[] @relation("AccessRequester")
  reviewedAccessRequests        AccessRequest[] @relation("AccessReviewer")
  performanceReviews            PerformanceReview[] @relation("ReviewSubject")
  performanceReviewsGiven       PerformanceReview[] @relation("ReviewAuthor")
  criticalRolesHeld             CriticalRole[] @relation("CriticalRoleHolder")
  successionCandidacies         SuccessionSuccessor[] @relation("SuccessionCandidate")
  talentOpportunitiesPosted     TalentOpportunity[] @relation("OpportunityPoster")
  mobilityApplications          MobilityApplication[] @relation("MobilityApplicant")
  identities           UserIdentity[]
  userScreenOverrides  UserScreenOverride[]
  screenOverridesCreated UserScreenOverride[] @relation("ScreenOverrideCreator")
  screenAccessAudits   ScreenAccessAudit[] @relation("ScreenAccessAuditActor")

  @@index([email])
  @@index([roleId])
  @@index([departmentId])
  @@index([teamId])
  @@index([jobRoleId])
  @@index([experienceLevelId])
  @@index([managerId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model UserIdentity {
  id         String      @id @default(cuid())
  userId     String      @map("user_id")
  provider   SsoProvider
  externalId String      @map("external_id")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("user_identities")
}

model RefreshToken {
  id         String    @id @default(cuid())
  token      String    @unique
  userId     String    @map("user_id")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  rememberMe Boolean   @default(false) @map("remember_me")
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── Career & Job Structure ────────────────────────────────────

model JobRole {
  id           String    @id @default(cuid())
  title        String
  code         String    @unique
  description  String?
  departmentId String?   @map("department_id")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  department           Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  users                User[]
  skillRequirements    RoleSkillRequirement[]
  learningRoadmaps     LearningRoadmap[]
  weightageRules       SkillWeightageRule[]
  criticalRoles        CriticalRole[]
  talentOpportunities  TalentOpportunity[]

  @@index([code])
  @@index([departmentId])
  @@index([deletedAt])
  @@map("job_roles")
}

model ExperienceLevel {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  rank        Int
  description String?
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  users             User[]
  skillRequirements RoleSkillRequirement[]
  learningRoadmaps  LearningRoadmap[]
  weightageRules    SkillWeightageRule[]

  @@index([code])
  @@index([rank])
  @@index([deletedAt])
  @@map("experience_levels")
}

// ─── Skills ────────────────────────────────────────────────────

model SkillCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  parentId    String?   @map("parent_id")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  parent   SkillCategory?  @relation("SkillCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children SkillCategory[] @relation("SkillCategoryHierarchy")
  skills   Skill[]

  @@index([slug])
  @@index([parentId])
  @@index([deletedAt])
  @@map("skill_categories")
}

model Skill {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  categoryId  String    @map("category_id")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  category             SkillCategory              @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  employeeSkills       EmployeeSkill[]
  roleRequirements     RoleSkillRequirement[]
  relationsFrom        SkillRelation[]            @relation("SkillFrom")
  relationsTo          SkillRelation[]            @relation("SkillTo")
  courseMappings       SkillCourseMapping[]
  assessmentMappings   SkillAssessmentMapping[]
  certificateMappings  SkillCertificateMapping[]
  validityRule         SkillValidityRule?
  weightageRules       SkillWeightageRule[]
  levelPaths           SkillLevelPath[]
  workforceForecasts   WorkforceForecast[]

  @@index([slug])
  @@index([categoryId])
  @@index([deletedAt])
  @@map("skills")
}

model SkillLevel {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  rank        Int
  description String?
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  employeeSkills   EmployeeSkill[]
  roleRequirements RoleSkillRequirement[] @relation("RequiredSkillLevel")
  levelPaths       SkillLevelPath[]

  @@index([code])
  @@index([rank])
  @@index([deletedAt])
  @@map("skill_levels")
}

model EmployeeSkill {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  skillId      String    @map("skill_id")
  skillLevelId String    @map("skill_level_id")
  verifiedAt   DateTime? @map("verified_at")
  verifiedById String?   @map("verified_by_id")
  notes        String?
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user         User       @relation("EmployeeSkills", fields: [userId], references: [id], onDelete: Cascade)
  skill        Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillLevel   SkillLevel @relation(fields: [skillLevelId], references: [id], onDelete: Restrict)
  verifiedBy   User?      @relation("SkillVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
  @@index([skillLevelId])
  @@index([deletedAt])
  @@map("employee_skills")
}

model RoleSkillRequirement {
  id                  String    @id @default(cuid())
  jobRoleId           String    @map("job_role_id")
  experienceLevelId   String    @map("experience_level_id")
  skillId             String    @map("skill_id")
  requiredSkillLevelId String   @map("required_skill_level_id")
  isMandatory         Boolean   @default(true) @map("is_mandatory")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  jobRole            JobRole         @relation(fields: [jobRoleId], references: [id], onDelete: Cascade)
  experienceLevel    ExperienceLevel @relation(fields: [experienceLevelId], references: [id], onDelete: Cascade)
  skill              Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)
  requiredSkillLevel SkillLevel      @relation("RequiredSkillLevel", fields: [requiredSkillLevelId], references: [id], onDelete: Restrict)

  @@unique([jobRoleId, experienceLevelId, skillId])
  @@index([jobRoleId])
  @@index([experienceLevelId])
  @@index([skillId])
  @@index([deletedAt])
  @@map("role_skill_requirements")
}

model SkillRelation {
  id             String            @id @default(cuid())
  skillId        String            @map("skill_id")
  relatedSkillId String            @map("related_skill_id")
  relationType   SkillRelationType @default(RELATED) @map("relation_type")
  deletedAt      DateTime?         @map("deleted_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  skill        Skill @relation("SkillFrom", fields: [skillId], references: [id], onDelete: Cascade)
  relatedSkill Skill @relation("SkillTo", fields: [relatedSkillId], references: [id], onDelete: Cascade)

  @@unique([skillId, relatedSkillId])
  @@index([skillId])
  @@index([relatedSkillId])
  @@index([deletedAt])
  @@map("skill_relations")
}

model SkillCourseMapping {
  id              String    @id @default(cuid())
  skillId         String    @map("skill_id")
  courseId        String    @map("course_id")
  coveragePercent Int       @default(100) @map("coverage_percent")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  skill  Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([skillId, courseId])
  @@index([skillId])
  @@index([courseId])
  @@index([deletedAt])
  @@map("skill_course_mappings")
}

model SkillAssessmentMapping {
  id           String    @id @default(cuid())
  skillId      String    @map("skill_id")
  assessmentId String    @map("assessment_id")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  skill      Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([skillId, assessmentId])
  @@index([skillId])
  @@index([assessmentId])
  @@index([deletedAt])
  @@map("skill_assessment_mappings")
}

model SkillCertificateMapping {
  id                  String    @id @default(cuid())
  skillId             String    @map("skill_id")
  certificateTemplateId String    @map("certificate_template_id")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  skill               Skill               @relation(fields: [skillId], references: [id], onDelete: Cascade)
  certificateTemplate CertificateTemplate @relation(fields: [certificateTemplateId], references: [id], onDelete: Cascade)

  @@unique([skillId, certificateTemplateId])
  @@index([skillId])
  @@index([certificateTemplateId])
  @@index([deletedAt])
  @@map("skill_certificate_mappings")
}

model SkillValidityRule {
  id                           String    @id @default(cuid())
  skillId                      String    @unique @map("skill_id")
  validityDays                 Int       @default(365) @map("validity_days")
  gracePeriodDays              Int       @default(30) @map("grace_period_days")
  requiresRecertification      Boolean   @default(true) @map("requires_recertification")
  reassessmentDaysBeforeExpiry Int       @default(60) @map("reassessment_days_before_expiry")
  deletedAt                    DateTime? @map("deleted_at")
  createdAt                    DateTime  @default(now()) @map("created_at")
  updatedAt                    DateTime  @updatedAt @map("updated_at")

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([deletedAt])
  @@map("skill_validity_rules")
}

model SkillWeightageRule {
  id                String    @id @default(cuid())
  skillId           String    @map("skill_id")
  jobRoleId         String?   @map("job_role_id")
  experienceLevelId String?   @map("experience_level_id")
  weight            Int       @default(10)
  isMandatory       Boolean   @default(false) @map("is_mandatory")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  skill           Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)
  jobRole         JobRole?         @relation(fields: [jobRoleId], references: [id], onDelete: Cascade)
  experienceLevel ExperienceLevel? @relation(fields: [experienceLevelId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@index([jobRoleId])
  @@index([experienceLevelId])
  @@index([deletedAt])
  @@map("skill_weightage_rules")
}

model SkillLevelPath {
  id                    String    @id @default(cuid())
  skillId               String    @map("skill_id")
  skillLevelId          String    @map("skill_level_id")
  courseId              String?   @map("course_id")
  assessmentId          String?   @map("assessment_id")
  certificateTemplateId String?   @map("certificate_template_id")
  title                 String?
  description           String?
  estimatedDays         Int?      @map("estimated_days")
  sortOrder             Int       @default(0) @map("sort_order")
  deletedAt             DateTime? @map("deleted_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  skill               Skill                @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillLevel          SkillLevel           @relation(fields: [skillLevelId], references: [id], onDelete: Restrict)
  course              Course?              @relation(fields: [courseId], references: [id], onDelete: SetNull)
  assessment          Assessment?          @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  certificateTemplate CertificateTemplate? @relation(fields: [certificateTemplateId], references: [id], onDelete: SetNull)

  @@unique([skillId, skillLevelId])
  @@index([skillId])
  @@index([skillLevelId])
  @@index([sortOrder])
  @@index([deletedAt])
  @@map("skill_level_paths")
}

