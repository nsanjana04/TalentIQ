# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TalentIQ

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://talentiq:talentiq_secret@localhost:5433/talentiq?schema=public

# ─── Redis (rate limiting, caching) ────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication (JWT) ──────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────────
# Comma-separated allowed origins (defaults to NEXT_PUBLIC_APP_URL)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Monitoring (Sentry) ───────────────────────────────────────
# SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# SENTRY_ORG=
# SENTRY_PROJECT=

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── AWS S3 Storage ────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=talentiq-uploads

# ─── AI (Assessment generation & Copilot) ───────────────────────
# Provider: gemini (default) or openai
AI_LLM_PROVIDER=openai
AI_COPILOT_LLM_ENABLED=true
# Google Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# OpenAI — official SDK: npm package `openai` (installed)
# Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# Recommended for structured assessment JSON: gpt-4o-mini or gpt-4o
# OPENAI_MODEL=gpt-4o-mini

# ─── Udemy (optional — curriculum import via Affiliate API) ─────
# Create credentials at https://www.udemy.com/user/edit-api-clients/
# Without these, npm run fetch:udemy-curricula uses bundled snapshots (Udemy blocks scraping).
# UDEMY_CLIENT_ID=
# UDEMY_CLIENT_SECRET=

# ─── Seed Data ─────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@talentiq.com
SEED_ADMIN_PASSWORD=TalentIQ@2026

# ─── SSO (Microsoft Azure AD) ──────────────────────────────────
# Register an app in Azure AD with redirect URI:
#   {NEXT_PUBLIC_APP_URL}/api/auth/sso/callback
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_AZURE_TENANT_ID=
# Restrict sign-in to this email domain (default: ruggedmonitoring.com)
SSO_ALLOWED_EMAIL_DOMAIN=ruggedmonitoring.com

# ─── Docker Production (docker-compose.prod.yml) ────────────────
POSTGRES_USER=talentiq
POSTGRES_PASSWORD=
POSTGRES_DB=talentiq
APP_PORT=3000